node_modules/
demo/*/package-lock.json
dist/
build/
*.js.map

# TypeScript compiled output (if not using ts-node/tsx directly)
*.js
!*.config.js

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS
.DS_Store

# Editor
.vscode/
.idea/

# Temp files used during dev
/tmp/mpp_cookies.txt

# Copied from root at publish time
sdk/README.md

# Ship the built SDK output so git-based installs (consumed via a `github:`
# dependency) work without running a build. Overrides the dist/, *.js and
# *.js.map ignores above for this path only.
!sdk/dist/
!sdk/dist/**
